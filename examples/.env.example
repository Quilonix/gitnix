# ═══════════════════════════════════════════════════════════════
# Gitnix Events — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── GitHub / Gitnix Database ─────────────────────────────────
# Your GitHub Personal Access Token (needs repo scope)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# The repo to use as database (format: owner/repo-name)
GITHUB_REPO=your-username/events-db
# Master encryption password (pick something strong, never share)
DB_PASSWORD=change-me-to-a-strong-random-password

# ─── Authentication ───────────────────────────────────────────
# Secret key for signing JWT tokens (use a random 64+ char string)
JWT_SECRET=change-me-to-a-random-secret-string-at-least-64-chars
# Token expiry (e.g., 7d, 24h, 1h)
JWT_EXPIRES_IN=7d

# ─── Admin Setup ──────────────────────────────────────────────
# Default admin email (created on first run if no admins exist)
ADMIN_EMAIL=admin@example.com
# Default admin password (change immediately after first login)
ADMIN_PASSWORD=admin123changeme

# ─── Security ─────────────────────────────────────────────────
# Allowed origins for CORS (comma-separated, or * for dev)
CORS_ORIGIN=http://localhost:3000
# Rate limit: max requests per window per IP
RATE_LIMIT_MAX=100
# Rate limit window in minutes
RATE_LIMIT_WINDOW_MIN=15
